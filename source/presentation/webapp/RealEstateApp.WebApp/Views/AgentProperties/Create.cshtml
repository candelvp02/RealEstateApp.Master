@model SavePropertyViewModel
@{
    ViewData["Title"] = "Create Property";
}

<div class="form-container-real">
    <h3 class="mb-4"><i class="fa-solid fa-house-circle-check me-2"></i>Create New Property</h3>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-controller="AgentProperties" asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="PropertyTypeId" class="form-label"></label>
                <select asp-for="PropertyTypeId" class="form-select" asp-items="@(Model.PropertyTypes?.Select(t => new SelectListItem(t.Name, t.Id.ToString())))">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="PropertyTypeId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="SaleTypeId" class="form-label"></label>
                <select asp-for="SaleTypeId" class="form-select" asp-items="@(Model.SaleTypes?.Select(t => new SelectListItem(t.Name, t.Id.ToString())))">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="SaleTypeId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Price" class="form-label">Price (DOP)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Size" class="form-label">Size (m²)</label>
                <input asp-for="Size" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Size" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Bedrooms" class="form-label"></label>
                <input asp-for="Bedrooms" class="form-control" type="number" />
                <span asp-validation-for="Bedrooms" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Bathrooms" class="form-label"></label>
                <input asp-for="Bathrooms" class="form-control" type="number" />
                <span asp-validation-for="Bathrooms" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label class="form-label">Improvements</label>
                <div class="d-flex flex-wrap gap-3 p-3" style="border: 1.5px solid var(--color-border); border-radius: 10px;">
                    @if (Model.Improvements is not null)
                    {
                        @foreach (var improvement in Model.Improvements)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedImprovementIds" value="@improvement.Id"
                                       id="imp_@improvement.Id"
                                       checked="@(Model.SelectedImprovementIds.Contains(improvement.Id))" />
                                <label class="form-check-label" for="imp_@improvement.Id">@improvement.Name</label>
                            </div>
                        }
                    }
                </div>
                <span asp-validation-for="SelectedImprovementIds" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Images" class="form-label">Property Images (1 to 4)</label>
                <input asp-for="Images" type="file" class="form-control" multiple accept=".jpg,.jpeg,.png" />
                <span asp-validation-for="Images" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-accent flex-grow-1">
                <i class="fa-solid fa-floppy-disk me-1"></i>Create Property
            </button>
            <a asp-controller="AgentProperties" asp-action="Index" class="btn btn-outline-real" style="border-color: var(--color-border); color: var(--color-text-muted);">
                Back
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}