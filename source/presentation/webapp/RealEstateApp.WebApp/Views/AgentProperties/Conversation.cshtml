@model List<ConversationViewModel>
@{
    ViewData["Title"] = $"Conversation with {ViewBag.ClientName}";
}

<div class="mb-3">
    <a asp-controller="AgentProperties" asp-action="Details" asp-route-id="@ViewBag.PropertyId" class="btn btn-outline-real" style="border-color: var(--color-border); color: var(--color-text-muted);">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to property
    </a>
</div>

<div class="card-real p-4">
    <h5 class="mb-1"><i class="fa-solid fa-comments me-2"></i>Conversation with @ViewBag.ClientName</h5>
    <p class="text-muted small mb-4">Property Code #@ViewBag.PropertyCode</p>

    <div class="d-flex flex-column gap-3 mb-4" style="max-height: 420px; overflow-y: auto;">
        @if (Model.Count == 0)
        {
            <p class="text-muted text-center">No messages yet. Start the conversation below.</p>
        }
        else
        {
            @foreach (var message in Model)
            {
                var isAgent = message.SenderRole == "Agent";
                <div class="d-flex @(isAgent ? "justify-content-end" : "justify-content-start")">
                    <div style="max-width: 65%; padding: 0.75rem 1rem; border-radius: 14px; background-color: @(isAgent ? "var(--color-primary)" : "var(--color-bg)"); color: @(isAgent ? "#fff" : "var(--color-text)"); border: @(isAgent ? "none" : "1.5px solid var(--color-border)");">
                        <div class="small fw-semibold mb-1">@(isAgent ? "You" : ViewBag.ClientName)</div>
                        <div>@message.Content</div>
                        <div class="small mt-1" style="opacity: 0.7;">@message.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</div>
                    </div>
                </div>
            }
        }
    </div>

    <form asp-controller="AgentProperties" asp-action="SendReply" method="post">
        <input type="hidden" name="PropertyId" value="@ViewBag.PropertyId" />
        <input type="hidden" name="ClientId" value="@ViewBag.ClientId" />
        <div class="input-group">
            <input type="text" name="Content" class="form-control" placeholder="Write your reply..." required />
            <button type="submit" class="btn btn-accent">
                <i class="fa-solid fa-paper-plane me-1"></i>Send Reply
            </button>
        </div>
    </form>
</div>