@model DeletePropertyViewModel
@{
    ViewData["Title"] = "Delete Property";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="form-container-real text-center">
            <i class="fa-solid fa-triangle-exclamation fa-2x mb-3" style="color: var(--color-danger);"></i>
            <h4>Are you sure you want to delete this property?</h4>

            <div class="card-real my-4 mx-auto" style="max-width: 300px;">
                <img src="@(string.IsNullOrEmpty(Model.MainImagePath) ? "/images/no-image.png" : Model.MainImagePath)"
                     class="card-img-top" alt="@Model.PropertyTypeName" />
                <div class="card-body">
                    <span class="badge-property-type">@Model.PropertyTypeName</span>
                    <p class="text-muted small mt-2 mb-0">Code: #@Model.Code</p>
                </div>
            </div>

            <form asp-controller="AgentProperties" asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-controller="AgentProperties" asp-action="Index" class="btn btn-outline-real" style="border-color: var(--color-border); color: var(--color-text-muted);">
                        Cancel
                    </a>
                    <button type="submit" class="btn" style="background-color: var(--color-danger); color: #fff; border-radius: 10px; padding: 0.55rem 1.4rem; font-weight: 600;">
                        <i class="fa-solid fa-trash me-1"></i>Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>