@model List<PropertyListItemViewModel>
@{
    ViewData["Title"] = "Property Maintenance";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0"><i class="fa-solid fa-list-check me-2"></i>Property Maintenance</h2>
    <a asp-controller="AgentProperties" asp-action="Create" class="btn btn-accent">
        <i class="fa-solid fa-plus me-1"></i>Create Property
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <i class="fa-solid fa-house-circle-xmark"></i>
        <p>@ViewBag.NoPropertiesMessage</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var property in Model)
        {
            <div class="col-md-4">
                <div class="card-real">
                    <img src="@(string.IsNullOrEmpty(property.MainImagePath) ? "/images/no-image.png" : property.MainImagePath)"
                         class="card-img-top" alt="@property.PropertyTypeName" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge-property-type">@property.PropertyTypeName</span>
                            <span class="text-muted small">#@property.Code</span>
                        </div>
                        <h5 class="card-title">@property.SaleTypeName</h5>
                        <p class="price-tag mb-2">RD$ @property.Price.ToString("N2")</p>
                        <div class="property-meta d-flex gap-3 mb-3">
                            <span><i class="fa-solid fa-bed"></i>@property.Bedrooms</span>
                            <span><i class="fa-solid fa-bath"></i>@property.Bathrooms</span>
                            <span><i class="fa-solid fa-ruler-combined"></i>@property.Size m²</span>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-controller="AgentProperties" asp-action="Edit" asp-route-id="@property.Id" class="btn btn-outline-real flex-grow-1" style="border-color: var(--color-primary);">
                                <i class="fa-solid fa-pen me-1"></i>Edit
                            </a>
                            <a asp-controller="AgentProperties" asp-action="Delete" asp-route-id="@property.Id" class="btn btn-outline-real" style="border-color: var(--color-danger); color: var(--color-danger);">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}