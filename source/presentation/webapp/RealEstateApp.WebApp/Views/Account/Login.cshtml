@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="form-container-real">
            <div class="text-center mb-4">
                <i class="fa-solid fa-house-lock fa-2x mb-2" style="color: var(--color-primary);"></i>
                <h3>Sign In to your account</h3>
                <p class="text-muted">Access your dashboard as Client, Agent or Admin.</p>
            </div>

            <div asp-validation-summary="All" class="alert alert-danger" style="display:none;" id="validationSummary"></div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="UserNameOrEmail" class="form-label"></label>
                    <input asp-for="UserNameOrEmail" class="form-control" placeholder="e.g. agent@realestateapp.com" />
                    <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-accent w-100 mt-2">
                    <i class="fa-solid fa-right-to-bracket me-1"></i>Sign In
                </button>
            </form>

            <div class="text-center mt-4">
                <span class="text-muted">Don't have an account?</span>
                <a asp-controller="Account" asp-action="Register" class="fw-semibold" style="color: var(--color-primary);">Join the app</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}