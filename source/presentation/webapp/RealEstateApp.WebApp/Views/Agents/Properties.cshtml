@model List<PropertyListItemViewModel>
@{
    ViewData["Title"] = $"{ViewBag.AgentFullName} - Properties";
}

<div class="mb-4">
    <a asp-controller="Agents" asp-action="Index" class="btn btn-outline-real" style="border-color: var(--color-border); color: var(--color-text-muted);">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to agents
    </a>
</div>

<div class="d-flex align-items-center gap-3 mb-4">
    <img src="@(string.IsNullOrEmpty((string)ViewBag.AgentProfilePicturePath) ? "/images/no-avatar.png" : ViewBag.AgentProfilePicturePath)"
         class="rounded-circle" style="width: 70px; height: 70px; object-fit: cover;" alt="@ViewBag.AgentFullName" />
    <div>
        <h3 class="mb-0">@ViewBag.AgentFullName</h3>
        <span class="text-muted">Available Properties</span>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <i class="fa-solid fa-house-circle-xmark"></i>
        <p>@ViewBag.NoPropertiesMessage</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var property in Model)
        {
            <div class="col-md-4">
                <a asp-controller="Home" asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none text-reset">
                    <div class="card-real">
                        <img src="@(string.IsNullOrEmpty(property.MainImagePath) ? "/images/no-image.png" : property.MainImagePath)"
                             class="card-img-top" alt="@property.PropertyTypeName" />
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge-property-type">@property.PropertyTypeName</span>
                                <span class="text-muted small">#@property.Code</span>
                            </div>
                            <h5 class="card-title">@property.SaleTypeName</h5>
                            <p class="price-tag mb-2">RD$ @property.Price.ToString("N2")</p>
                            <div class="property-meta d-flex gap-3">
                                <span><i class="fa-solid fa-bed"></i>@property.Bedrooms</span>
                                <span><i class="fa-solid fa-bath"></i>@property.Bathrooms</span>
                                <span><i class="fa-solid fa-ruler-combined"></i>@property.Size m²</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}