@{
    ViewData["Title"] = "Access Denied";
}

<div class="access-denied-box">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <h2>Access Denied</h2>
    <p class="text-muted">You do not have permission to access this section.</p>

    @if (User.IsInRole("Client"))
    {
        <a class="btn btn-primary-real mt-2" asp-controller="Client" asp-action="Index">Go to my Home</a>
    }
    else if (User.IsInRole("Agent"))
    {
        <a class="btn btn-primary-real mt-2" asp-controller="AgentProperties" asp-action="AgentHome">Go to my Home</a>
    }
    else if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary-real mt-2" asp-controller="AdminHome" asp-action="Index">Go to my Home</a>
    }
    else
    {
        <a class="btn btn-primary-real mt-2" asp-controller="Home" asp-action="Index">Go to Home</a>
    }
</div>